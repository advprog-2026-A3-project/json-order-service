# Database (required)
DB_URL=jdbc:postgresql://your-host:5432/your-db
DB_USERNAME=your-username
DB_PASSWORD=your-password

# Optional: Supabase naming fallback if you prefer
SUPABASE_DB_URL=
SUPABASE_DB_USERNAME=
SUPABASE_DB_PASSWORD=

# Docker Compose local services
POSTGRES_DB=orderdb
POSTGRES_USER=orderuser
POSTGRES_PASSWORD=orderpassword
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-this

# Optional services
VOUCHER_SERVICE_BASE_URL=http://localhost:8080

